    {
      "standarized": true,
      "id": "rain-of-blades",
      "name": "滂沱剑雨",
      "type": "domain",
      "description": "**花费 1 希望点** 进行一次**施法掷骰**，召唤出数把投掷利剑，攻击邻近范围内的所有目标。你成功对抗的目标将受到使用你的熟练度的**d8+2**点魔法伤害。\n如果你命中的目标处于 *脆弱* 状态，其会额外受到**1d8**点伤害。",
      "imageUrl": "/builtin-cards/domain/rain-of-blades.webp",
