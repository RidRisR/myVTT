# Server port (shared between server and client)
VITE_SERVER_PORT=4444

# Vite dev server port
VITE_DEV_PORT=5173

# LevelDB persistence directory (default: ./db)
# YPERSISTENCE=./db

# Upload file directory (default: server/uploads)
# UPLOADS_DIR=

# Server bind host (default: 0.0.0.0)
# HOST=0.0.0.0
